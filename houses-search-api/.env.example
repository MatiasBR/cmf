# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Houses Search API
API_VERSION=1.0.0

# Database
DATABASE_FILE=houses.db

# CSV Data Source
CSV_URL=https://getgloby-realtor-challenge.s3.us-east-1.amazonaws.com/realtor-data.csv

# Demographics API
DEMOGRAPHICS_API_TIMEOUT=10
DEMOGRAPHICS_CACHE_TTL_HOURS=24

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=*
